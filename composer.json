{
  "name": "if-instrument/umkm-solution",
  "description": "IF Instrument UMKM Solution - POS, Inventory, Product Recipe, and SaaS Operations",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "codeigniter4/framework": "^4.7"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Config\\": "app/Config/"
    },
    "exclude-from-classmap": [
      "app/Database/Migrations/"
    ]
  },
  "scripts": {
    "serve": "php spark serve",
    "migrate": "php spark migrate",
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
