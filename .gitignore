# Local environment
.env
.env.*
!.env.example

# Dependencies
/vendor/
/node_modules/

# CodeIgniter writable runtime files
/writable/cache/*
/writable/debugbar/*
/writable/logs/*
/writable/session/*
/writable/uploads/*
!/writable/cache/.gitkeep
!/writable/debugbar/.gitkeep
!/writable/logs/.gitkeep
!/writable/session/.gitkeep
!/writable/uploads/.gitkeep

# User uploaded assets
/public/uploads/*
!/public/uploads/.gitkeep

# Test and coverage output
/coverage/
/.phpunit.cache/

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Temporary files
*.tmp
*.temp
*.log

# Generated config files
if-instrument*.conf
